// Stroman OS — Prisma schema (persistence layer, Prompt 005).
//
// This schema is an INFRASTRUCTURE detail beneath the domain. It models the
// domain aggregates faithfully; it does not redefine them. Prisma types never
// leak above src/infrastructure. See docs/PERSISTENCE_ARCHITECTURE.md.
//
// Identifiers are the domain's branded string ids (generated by the application),
// so primary keys are String, never autoincrement. Timestamps are supplied by the
// application clock and stored timezone-aware; the database does not override them.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ContentType {
  FIRST_PRINCIPLE
  PROTOCOL
  STANDARD
  ENGINE
  TOOL
  PLAYBOOK
  RUBRIC
  DECISION_TREE
  CASE_STUDY
  TAXONOMY_TERM
  AI_MODULE
}

enum DecisionStatus {
  PROPOSED
  DECIDED
}

enum ReviewerType {
  HUMAN
  AI
}

enum StoryAngleStatus {
  DRAFT
  EVALUATED
  SELECTED
  ARCHIVED
}

enum EvidenceRole {
  PRIMARY
  SUPPORTING
  CONTEXTUAL
  COUNTERPOINT
}

enum EvidenceProvenanceKind {
  MEDIA_ASSET
  TRANSCRIPT_SEGMENT
}

enum StoryRecommendation {
  SELECT
  REVISE
  ARCHIVE
}

enum CriticType {
  AI
  HUMAN
}

enum KnowledgeSourceType {
  UPLOAD
  WEB_PAGE
  MANUAL
}

enum SourceReliability {
  VERIFIED
  HIGH
  MEDIUM
  LOW
  UNKNOWN
}

enum KnowledgeSourceStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum DocumentType {
  TRANSCRIPT
  ARTICLE
  WEB_PAGE
  SOCIAL_POST
  PDF
  VIDEO
  NOTE
}

enum AcquisitionRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  PARTIALLY_SUCCEEDED
  FAILED
}

enum ObservationKind {
  ENTITY
  MEMORY
  INSIGHT
  RELATIONSHIP
}

enum ObservationOrigin {
  AI
  HUMAN
  IMPORT
}

enum ObservationStatus {
  PENDING_REVIEW
  ACCEPTED
  REJECTED
}

enum ReviewOutcome {
  ACCEPT
  EDIT_AND_ACCEPT
  REJECT
}

enum AccountStatus {
  ACTIVE
  DISABLED
}

enum AuthProvider {
  SUPABASE
}

/// An internal Stroman OS user — the stable business identity that owns data.
/// Generated by Stroman OS (not the auth provider), so it survives a provider
/// migration. Ownership model (Option A): a Project's `owner_id` equals a User's
/// `id`. That equality is enforced at the application layer, NOT by a foreign key:
/// business records must never cascade-delete when an identity is removed, and
/// pre-existing owner references must not require fabricated user rows.
model User {
  id        String        @id
  status    AccountStatus @default(ACTIVE)
  createdAt DateTime      @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime      @map("updated_at") @db.Timestamptz(3)

  identities UserIdentity[]

  @@map("users")
}

/// Verified mapping from an external provider identity to an internal user. The
/// `(provider, provider_subject)` pair is unique and is the ONLY key used to
/// resolve a returning user; the unique constraint makes first-login provisioning
/// race-safe. `normalized_email` is retained for audit/support only.
model UserIdentity {
  id                  String       @id
  userId              String       @map("user_id")
  provider            AuthProvider
  providerSubject     String       @map("provider_subject")
  normalizedEmail     String?      @map("normalized_email")
  createdAt           DateTime     @map("created_at") @db.Timestamptz(3)
  lastAuthenticatedAt DateTime     @map("last_authenticated_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([provider, providerSubject])
  @@index([userId])
  @@map("user_identities")
}

/// A unit of creative work. `ownerId` equals the owning `User.id` (see `User`);
/// the reference is validated at the application layer, not by a database FK.
model Project {
  id          String        @id
  ownerId     String        @map("owner_id")
  name        String
  status      ProjectStatus
  createdAt   DateTime      @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime      @map("updated_at") @db.Timestamptz(3)
  lockVersion Int           @default(1) @map("lock_version")

  evaluations        Evaluation[]
  decisions          Decision[]
  creativeBrief      CreativeBrief?
  storyAngles        StoryAngle[]
  mediaAssets        MediaAsset[]
  transcripts        TranscriptDocument[]
  evidenceReferences EvidenceReference[]

  @@unique([id, ownerId])
  @@index([ownerId])
  @@map("projects")
}

model MediaAsset {
  id          String   @id
  ownerId     String   @map("owner_id")
  projectId   String   @map("project_id")
  fileName    String   @map("file_name")
  mediaType   String   @map("media_type")
  byteSize    Int      @map("byte_size")
  contentHash String   @map("content_hash")
  createdAt   DateTime @map("created_at") @db.Timestamptz(3)

  project            Project             @relation(fields: [projectId, ownerId], references: [id, ownerId], onDelete: Restrict)
  transcript         TranscriptDocument?
  evidenceReferences EvidenceReference[]

  @@unique([id, ownerId, projectId])
  @@index([projectId])
  @@map("media_assets")
}

model TranscriptDocument {
  id           String   @id
  ownerId      String   @map("owner_id")
  projectId    String   @map("project_id")
  mediaAssetId String   @unique @map("media_asset_id")
  title        String
  createdAt    DateTime @map("created_at") @db.Timestamptz(3)

  project            Project             @relation(fields: [projectId, ownerId], references: [id, ownerId], onDelete: Restrict)
  mediaAsset         MediaAsset          @relation(fields: [mediaAssetId, ownerId, projectId], references: [id, ownerId, projectId], onDelete: Restrict)
  speakers           TranscriptSpeaker[]
  segments           TranscriptSegment[]
  evidenceReferences EvidenceReference[]

  @@unique([id, ownerId, projectId, mediaAssetId])
  @@unique([mediaAssetId, ownerId, projectId])
  @@index([projectId])
  @@index([mediaAssetId])
  @@map("transcript_documents")
}

model TranscriptSpeaker {
  transcriptDocumentId String @map("transcript_document_id")
  id                   String
  label                String

  transcript TranscriptDocument  @relation(fields: [transcriptDocumentId], references: [id], onDelete: Cascade)
  segments   TranscriptSegment[]

  @@id([transcriptDocumentId, id])
  @@index([transcriptDocumentId])
  @@map("transcript_speakers")
}

model TranscriptSegment {
  transcriptDocumentId String  @map("transcript_document_id")
  id                   String
  sequence             Int
  speakerId            String? @map("speaker_id")
  text                 String
  startMs              Int?    @map("start_ms")
  endMs                Int?    @map("end_ms")

  transcript         TranscriptDocument  @relation(fields: [transcriptDocumentId], references: [id], onDelete: Cascade)
  speaker            TranscriptSpeaker?  @relation(fields: [transcriptDocumentId, speakerId], references: [transcriptDocumentId, id], onDelete: Restrict)
  evidenceReferences EvidenceReference[]

  @@id([transcriptDocumentId, id])
  @@unique([transcriptDocumentId, sequence])
  @@index([transcriptDocumentId, sequence])
  @@map("transcript_segments")
}

model EvidenceReference {
  id                   String                 @id
  ownerId              String                 @map("owner_id")
  projectId            String                 @map("project_id")
  provenanceKind       EvidenceProvenanceKind @map("provenance_kind")
  mediaAssetId         String                 @map("media_asset_id")
  transcriptDocumentId String?                @map("transcript_document_id")
  transcriptSegmentId  String?                @map("transcript_segment_id")
  createdAt            DateTime               @map("created_at") @db.Timestamptz(3)

  project           Project             @relation(fields: [projectId, ownerId], references: [id, ownerId], onDelete: Restrict)
  mediaAsset        MediaAsset          @relation(fields: [mediaAssetId, ownerId, projectId], references: [id, ownerId, projectId], onDelete: Restrict)
  transcript        TranscriptDocument? @relation(fields: [transcriptDocumentId, ownerId, projectId, mediaAssetId], references: [id, ownerId, projectId, mediaAssetId], onDelete: Restrict)
  transcriptSegment TranscriptSegment?  @relation(fields: [transcriptDocumentId, transcriptSegmentId], references: [transcriptDocumentId, id], onDelete: Restrict)

  @@index([projectId, createdAt])
  @@index([mediaAssetId, createdAt])
  @@index([transcriptDocumentId, createdAt])
  @@map("evidence_references")
}

/// The creator-supplied context Stroman OS analyzes into a Creative Blueprint.
/// One brief per project (project_id is unique); cascades with its project.
model CreativeBrief {
  id             String   @id
  projectId      String   @unique @map("project_id")
  title          String
  client         String
  projectType    String   @map("project_type")
  creativeGoal   String   @map("creative_goal")
  targetAudience String   @map("target_audience")
  desiredEmotion String   @map("desired_emotion")
  context        String
  createdAt      DateTime @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @map("updated_at") @db.Timestamptz(3)
  lockVersion    Int      @default(1) @map("lock_version")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("creative_briefs")
}

/// Knowledge-base content item. Slug uniqueness is enforced by the database.
model ContentItem {
  id          String        @id
  type        ContentType
  slug        String        @unique
  title       String
  status      ContentStatus
  version     Int
  createdAt   DateTime      @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime      @map("updated_at") @db.Timestamptz(3)
  lockVersion Int           @default(1) @map("lock_version")

  @@map("content_items")
}

/// Rubric aggregate root. Criteria are owned children.
model Rubric {
  id          String            @id
  slug        String            @unique
  title       String
  criteria    RubricCriterion[]
  evaluations Evaluation[]

  @@map("rubrics")
}

/// A criterion owned by exactly one rubric. `position` preserves domain ordering.
model RubricCriterion {
  id         String @id
  rubricId   String @map("rubric_id")
  name       String
  weight     Float
  anchorOne  String @map("anchor_one")
  anchorFive String @map("anchor_five")
  anchorTen  String @map("anchor_ten")
  position   Int

  rubric Rubric @relation(fields: [rubricId], references: [id], onDelete: Cascade)

  @@index([rubricId])
  @@map("rubric_criteria")
}

/// A recorded, rubric-based scoring of a project. Immutable once created.
model Evaluation {
  id           String            @id
  projectId    String            @map("project_id")
  rubricId     String            @map("rubric_id")
  reviewerType ReviewerType      @map("reviewer_type")
  reviewerId   String?           @map("reviewer_id")
  createdAt    DateTime          @map("created_at") @db.Timestamptz(3)
  scores       EvaluationScore[]

  project Project @relation(fields: [projectId], references: [id], onDelete: Restrict)
  rubric  Rubric  @relation(fields: [rubricId], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@map("evaluations")
}

/// One criterion score within an evaluation. Composite PK enforces the domain's
/// "no duplicate criterion per evaluation" invariant at the database level.
model EvaluationScore {
  evaluationId  String @map("evaluation_id")
  criterionId   String @map("criterion_id")
  score         Int
  justification String

  evaluation Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@id([evaluationId, criterionId])
  @@map("evaluation_scores")
}

/// A recorded creative decision. Human-authority fields (selected option, decided
/// by, rationale) are stored separately from AI advisory fields.
model Decision {
  id                          String         @id
  projectId                   String         @map("project_id")
  question                    String
  status                      DecisionStatus
  selectedOptionId            String?        @map("selected_option_id")
  decidedBy                   String?        @map("decided_by")
  decisionRationale           String?        @map("decision_rationale")
  advisoryRecommendedOptionId String?        @map("advisory_recommended_option_id")
  advisoryRationale           String?        @map("advisory_rationale")
  advisoryConfidence          Float?         @map("advisory_confidence")
  createdAt                   DateTime       @map("created_at") @db.Timestamptz(3)
  decidedAt                   DateTime?      @map("decided_at") @db.Timestamptz(3)
  lockVersion                 Int            @default(1) @map("lock_version")

  project  Project            @relation(fields: [projectId], references: [id], onDelete: Restrict)
  options  DecisionOption[]
  evidence DecisionEvidence[]

  @@index([projectId])
  @@map("decisions")
}

/// A supporting-evidence entry behind a decision's advisory. Owned child of the
/// decision aggregate (replaced wholesale when the advisory is attached), so it
/// cascades with its decision. `position` preserves ordering.
model DecisionEvidence {
  decisionId  String @map("decision_id")
  position    Int
  sourceLabel String @map("source_label")
  observation String
  relevance   String

  decision Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  @@id([decisionId, position])
  @@map("decision_evidence")
}

/// An option owned by exactly one decision. Composite PK enforces unique option
/// ids within a decision. `position` preserves domain ordering.
model DecisionOption {
  decisionId String  @map("decision_id")
  id         String
  label      String
  rationale  String?
  position   Int

  decision Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  @@id([decisionId, id])
  @@map("decision_options")
}

// ── Memory Engine (creative knowledge graph) ─────────────────────────────────
// Owner-scoped, append-only records. `owner_id` is an external identity reference
// (equals the internal user id), consistent with Project.

/// A node in the knowledge graph (person, organization, place, concept…).
model Entity {
  id        String   @id
  ownerId   String   @map("owner_id")
  name      String
  kind      String
  createdAt DateTime @map("created_at") @db.Timestamptz(3)

  memories          Memory[]
  relationshipsFrom Relationship[] @relation("RelationshipFrom")
  relationshipsTo   Relationship[] @relation("RelationshipTo")

  @@index([ownerId])
  @@map("entities")
}

/// Provenance for knowledge (interview, article, note…).
model Source {
  id         String   @id
  ownerId    String   @map("owner_id")
  label      String
  sourceType String   @map("source_type")
  url        String?
  detail     String?
  createdAt  DateTime @map("created_at") @db.Timestamptz(3)

  memories Memory[]

  @@index([ownerId])
  @@map("sources")
}

/// A discrete fact/observation about an entity, optionally traceable to a source.
model Memory {
  id        String   @id
  ownerId   String   @map("owner_id")
  entityId  String   @map("entity_id")
  sourceId  String?  @map("source_id")
  content   String
  createdAt DateTime @map("created_at") @db.Timestamptz(3)

  entity        Entity          @relation(fields: [entityId], references: [id], onDelete: Restrict)
  source        Source?         @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  insightRefs   InsightMemory[]
  storyEvidence StoryEvidence[]

  @@index([ownerId])
  @@index([entityId])
  @@index([sourceId])
  @@map("memories")
}

/// A directed, typed link between two entities.
model Relationship {
  id           String   @id
  ownerId      String   @map("owner_id")
  fromEntityId String   @map("from_entity_id")
  toEntityId   String   @map("to_entity_id")
  relationType String   @map("relation_type")
  createdAt    DateTime @map("created_at") @db.Timestamptz(3)

  fromEntity Entity @relation("RelationshipFrom", fields: [fromEntityId], references: [id], onDelete: Restrict)
  toEntity   Entity @relation("RelationshipTo", fields: [toEntityId], references: [id], onDelete: Restrict)

  @@index([ownerId])
  @@index([fromEntityId])
  @@index([toEntityId])
  @@map("relationships")
}

/// A conclusion derived from one or more memories, with confidence and evidence.
model Insight {
  id         String   @id
  ownerId    String   @map("owner_id")
  statement  String
  confidence Float
  evidence   String?
  createdAt  DateTime @map("created_at") @db.Timestamptz(3)

  memories      InsightMemory[]
  storyEvidence StoryEvidence[]

  @@index([ownerId])
  @@map("insights")
}

/// Join: the memories an insight cites (its traceable evidence). >= 1 enforced in
/// the domain/service. A memory cannot be deleted while an insight references it.
model InsightMemory {
  insightId String @map("insight_id")
  memoryId  String @map("memory_id")

  insight Insight @relation(fields: [insightId], references: [id], onDelete: Cascade)
  memory  Memory  @relation(fields: [memoryId], references: [id], onDelete: Restrict)

  @@id([insightId, memoryId])
  @@index([memoryId])
  @@map("insight_memories")
}

// ── Story Reasoning Engine ───────────────────────────────────────────────────
// Candidate story angles for a project, their cited evidence (traced to the
// Memory Engine), and scored critiques. Owner-scoped; the angle is a mutable
// aggregate (lifecycle + lockVersion), evidence and critiques are append-only.

/// A candidate narrative direction for a project. At most one SELECTED angle per
/// project is enforced by a partial unique index (see the migration).
model StoryAngle {
  id              String           @id
  ownerId         String           @map("owner_id")
  projectId       String           @map("project_id")
  title           String
  theme           String
  premise         String
  audiencePromise String           @map("audience_promise")
  centralQuestion String           @map("central_question")
  status          StoryAngleStatus
  createdAt       DateTime         @map("created_at") @db.Timestamptz(3)
  lockVersion     Int              @default(1) @map("lock_version")

  project   Project         @relation(fields: [projectId], references: [id], onDelete: Restrict)
  evidence  StoryEvidence[]
  critiques StoryCritique[]

  @@index([ownerId])
  @@index([projectId])
  @@map("story_angles")
}

/// A single citation linking an angle to exactly one memory-graph node (memory OR
/// insight; the XOR is enforced by a CHECK constraint in the migration). A cited
/// node cannot be deleted while evidence references it.
model StoryEvidence {
  id           String       @id
  ownerId      String       @map("owner_id")
  storyAngleId String       @map("story_angle_id")
  memoryId     String?      @map("memory_id")
  insightId    String?      @map("insight_id")
  role         EvidenceRole
  reason       String
  createdAt    DateTime     @map("created_at") @db.Timestamptz(3)

  storyAngle StoryAngle @relation(fields: [storyAngleId], references: [id], onDelete: Cascade)
  memory     Memory?    @relation(fields: [memoryId], references: [id], onDelete: Restrict)
  insight    Insight?   @relation(fields: [insightId], references: [id], onDelete: Restrict)

  @@index([ownerId])
  @@index([storyAngleId])
  @@index([memoryId])
  @@index([insightId])
  @@map("story_evidence")
}

/// A scored, qualitative assessment of an angle across six creative dimensions
/// (each an integer 1–10, enforced by CHECK constraints), plus an advisory
/// recommendation. Recording a critique never transitions the angle.
model StoryCritique {
  id                 String              @id
  ownerId            String              @map("owner_id")
  storyAngleId       String              @map("story_angle_id")
  criticType         CriticType          @map("critic_type")
  criticId           String?             @map("critic_id")
  evidenceStrength   Int                 @map("evidence_strength")
  emotionalPotential Int                 @map("emotional_potential")
  visualPotential    Int                 @map("visual_potential")
  brandAlignment     Int                 @map("brand_alignment")
  originality        Int
  interviewPotential Int                 @map("interview_potential")
  strengths          String
  weaknesses         String
  recommendation     StoryRecommendation
  rationale          String
  createdAt          DateTime            @map("created_at") @db.Timestamptz(3)

  storyAngle StoryAngle @relation(fields: [storyAngleId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([storyAngleId])
  @@map("story_critiques")
}

model KnowledgeSource {
  id                String                @id
  ownerId           String                @map("owner_id")
  name              String
  sourceType        KnowledgeSourceType   @map("source_type")
  origin            String?
  sourceReliability SourceReliability     @map("source_reliability")
  status            KnowledgeSourceStatus
  createdAt         DateTime              @map("created_at") @db.Timestamptz(3)
  lockVersion       Int                   @default(1) @map("lock_version")

  documents    SourceDocument[]
  runs         AcquisitionRun[]
  observations KnowledgeObservation[]

  @@index([ownerId])
  @@map("knowledge_sources")
}

model SourceDocument {
  id                String       @id
  ownerId           String       @map("owner_id")
  knowledgeSourceId String       @map("knowledge_source_id")
  documentType      DocumentType @map("document_type")
  contentHash       String       @map("content_hash")
  title             String
  mediaType         String?      @map("media_type")
  byteSize          Int?         @map("byte_size")
  createdAt         DateTime     @map("created_at") @db.Timestamptz(3)

  knowledgeSource KnowledgeSource        @relation(fields: [knowledgeSourceId], references: [id], onDelete: Restrict)
  observations    KnowledgeObservation[]

  @@unique([knowledgeSourceId, contentHash])
  @@index([ownerId])
  @@index([knowledgeSourceId])
  @@map("source_documents")
}

model AcquisitionRun {
  id                  String               @id
  ownerId             String               @map("owner_id")
  knowledgeSourceId   String               @map("knowledge_source_id")
  extractor           String
  extractorVersion    String               @map("extractor_version")
  status              AcquisitionRunStatus
  startedAt           DateTime?            @map("started_at") @db.Timestamptz(3)
  finishedAt          DateTime?            @map("finished_at") @db.Timestamptz(3)
  documentsProcessed  Int?                 @map("documents_processed")
  observationsCreated Int?                 @map("observations_created")
  failureCount        Int?                 @map("failure_count")
  createdAt           DateTime             @map("created_at") @db.Timestamptz(3)
  lockVersion         Int                  @default(1) @map("lock_version")

  knowledgeSource KnowledgeSource        @relation(fields: [knowledgeSourceId], references: [id], onDelete: Restrict)
  observations    KnowledgeObservation[]

  @@index([ownerId])
  @@index([knowledgeSourceId])
  @@map("acquisition_runs")
}

model KnowledgeObservation {
  id                String            @id
  ownerId           String            @map("owner_id")
  observationType   ObservationKind   @map("observation_type")
  payload           Json
  sourceDocumentId  String            @map("source_document_id")
  knowledgeSourceId String            @map("knowledge_source_id")
  acquisitionRunId  String?           @map("acquisition_run_id")
  location          Json?
  confidence        Float?
  createdBy         ObservationOrigin @map("created_by")
  status            ObservationStatus
  createdAt         DateTime          @map("created_at") @db.Timestamptz(3)
  lockVersion       Int               @default(1) @map("lock_version")

  sourceDocument   SourceDocument               @relation(fields: [sourceDocumentId], references: [id], onDelete: Restrict)
  knowledgeSource  KnowledgeSource              @relation(fields: [knowledgeSourceId], references: [id], onDelete: Restrict)
  acquisitionRun   AcquisitionRun?              @relation(fields: [acquisitionRunId], references: [id], onDelete: Restrict)
  review           KnowledgeReview?
  materializations ObservationMaterialization[]

  @@index([ownerId])
  @@index([sourceDocumentId])
  @@index([acquisitionRunId])
  @@index([knowledgeSourceId])
  @@map("knowledge_observations")
}

model KnowledgeReview {
  id                     String        @id
  ownerId                String        @map("owner_id")
  knowledgeObservationId String        @unique @map("knowledge_observation_id")
  outcome                ReviewOutcome
  reviewerId             String        @map("reviewer_id")
  note                   String?
  editedPayload          Json?         @map("edited_payload")
  reviewedAt             DateTime      @map("reviewed_at") @db.Timestamptz(3)
  createdAt              DateTime      @map("created_at") @db.Timestamptz(3)

  knowledgeObservation KnowledgeObservation         @relation(fields: [knowledgeObservationId], references: [id], onDelete: Restrict)
  materializations     ObservationMaterialization[]

  @@index([ownerId])
  @@map("knowledge_reviews")
}

model ObservationMaterialization {
  knowledgeObservationId String          @map("knowledge_observation_id")
  knowledgeReviewId      String          @map("knowledge_review_id")
  recordType             ObservationKind @map("record_type")
  recordId               String          @map("record_id")
  ownerId                String          @map("owner_id")
  createdAt              DateTime        @map("created_at") @db.Timestamptz(3)

  knowledgeObservation KnowledgeObservation @relation(fields: [knowledgeObservationId], references: [id], onDelete: Restrict)
  knowledgeReview      KnowledgeReview      @relation(fields: [knowledgeReviewId], references: [id], onDelete: Restrict)

  @@id([knowledgeObservationId, recordType])
  @@index([recordType, recordId])
  @@index([ownerId])
  @@index([knowledgeReviewId])
  @@map("observation_materializations")
}
