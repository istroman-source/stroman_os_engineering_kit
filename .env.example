# Stroman OS — environment template.
# Copy to `.env` and fill in. Never commit real secrets.
# All variables are validated at startup by `src/lib/env`.

# Runtime environment: development | test | production
NODE_ENV=development

# Public application URL (used for absolute links and callbacks).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostgreSQL connection string. Matches docker-compose.yml defaults.
DATABASE_URL=postgresql://stroman:stroman@localhost:5432/stroman_os?schema=public

# Comma-separated feature flags to force-enable in this environment.
# Example: FEATURE_FLAGS=council_v2,semantic_search
FEATURE_FLAGS=

# Minimum log level: debug | info | warn | error
LOG_LEVEL=debug

# --- Authentication (Supabase Auth). PLACEHOLDER-ONLY values below. ---
# Required in production (startup fails closed if missing); optional in dev/test
# where the authenticator is injected by test composition.
#
# Supabase project URL, e.g. https://<project-ref>.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co
# Publishable anon key (safe to send as the auth `apikey`; NOT the service_role key).
SUPABASE_ANON_KEY=your-supabase-anon-key
# Optional: legacy shared HS256 JWT secret. Leave unset to verify via the project
# JWKS endpoint (preferred for Supabase's asymmetric keys). NEVER commit a real one.
# SUPABASE_JWT_SECRET=
# Expected JWT audience (Supabase default).
SUPABASE_JWT_AUD=authenticated
# Comma-separated allowed browser origins for CSRF/Origin checks (defaults to
# NEXT_PUBLIC_APP_URL's origin). Set explicitly when behind a proxy/CDN.
APP_ALLOWED_ORIGINS=http://localhost:3000
# Same-origin URL the provider email link returns to (defaults to
# <NEXT_PUBLIC_APP_URL origin>/auth/callback). This EXACT value must be added to the
# Supabase project's Authentication → URL Configuration → Redirect URLs.
# SUPABASE_EMAIL_REDIRECT_URL=http://localhost:3000/auth/callback

# --- Live Supabase auth acceptance (Prompt 006B.1) — NOT runtime config. ---
# These belong in a SEPARATE, git-ignored `.env.auth-acceptance` used only by
# `npm run auth:acceptance` against an ISOLATED throwaway Supabase project.
# Placeholder-only; never commit real values. See docs/AUTHENTICATION_ARCHITECTURE.md.
#   STROMAN_AUTH_ACCEPTANCE_PROJECT=true      # explicit non-production opt-in (required)
#   AUTH_ACCEPTANCE_EMAIL=REPLACE_ME          # synthetic test inbox address
#   AUTH_ACCEPTANCE_SERVER=http://localhost:3000
#   SUPABASE_URL / SUPABASE_ANON_KEY          # the throwaway project's values
#
# Optional generateLink automation (for new Free projects with link-only templates):
#   AUTH_ACCEPTANCE_GENERATE_LINK=true        # opt in to admin-API OTP retrieval
#   SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME      # throwaway project ONLY; used only by
#                                             # the acceptance script; never printed.
